{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentientventures.local/contracts/api.v1.json",
  "$defs": {
    "validationDetail": {"type":"object","additionalProperties":false,"required":["path","code","message"],"properties":{"path":{"type":"string","minLength":1},"code":{"type":"string","minLength":1},"message":{"type":"string","minLength":1}}},
    "error": {"type":"object","additionalProperties":false,"required":["error"],"properties":{"error":{"type":"object","additionalProperties":false,"required":["code","message","details","requestId"],"properties":{"code":{"type":"string","minLength":1},"message":{"type":"string","minLength":1},"details":{"type":"array","items":{"$ref":"#/$defs/validationDetail"}},"requestId":{"type":"string","minLength":1}}}}},
    "job": {"type":"object","additionalProperties":false,"required":["id","companySlug","state","stage","progress","attempt","repairCount","updatedAt","error","retryAllowed"],"properties":{"id":{"$ref":"common.v1.json#/$defs/uuid"},"companySlug":{"$ref":"common.v1.json#/$defs/slug"},"state":{"type":"string","enum":["queued","validating","extracting","classifying","fact_extracting","council_preparing","pro_analysis","contra_analysis","judging","markdown_validating","repairing","scoring","indexing","ready","failed"]},"stage":{"type":"string","minLength":1},"progress":{"type":"integer","minimum":0,"maximum":100},"attempt":{"type":"integer","minimum":1,"maximum":2},"repairCount":{"type":"integer","minimum":0,"maximum":1},"updatedAt":{"$ref":"common.v1.json#/$defs/timestamp"},"error":{"type":["object","null"]},"retryAllowed":{"type":"boolean"}}},
    "submissionAccepted": {"type":"object","additionalProperties":false,"required":["company","job","acceptedAt"],"properties":{"company":{"type":"object","additionalProperties":false,"required":["id","slug","name"],"properties":{"id":{"$ref":"common.v1.json#/$defs/uuid"},"slug":{"$ref":"common.v1.json#/$defs/slug"},"name":{"type":"string","minLength":2,"maxLength":120}}},"job":{"type":"object","additionalProperties":false,"required":["id","state","statusUrl"],"properties":{"id":{"$ref":"common.v1.json#/$defs/uuid"},"state":{"const":"queued"},"statusUrl":{"type":"string","pattern":"^/api/v1/jobs/"}}},"acceptedAt":{"$ref":"common.v1.json#/$defs/timestamp"}}},
    "companySummary": {"type":"object","additionalProperties":false,"required":["slug","company","stage","submissionDate","overallScore","categoryScores"],"properties":{"slug":{"$ref":"common.v1.json#/$defs/slug"},"company":{"type":"string","minLength":1},"stage":{"type":["string","null"]},"submissionDate":{"$ref":"common.v1.json#/$defs/timestamp"},"overallScore":{"type":["integer","null"],"minimum":1,"maximum":100},"categoryScores":{"$ref":"common.v1.json#/$defs/categoryScores"}}},
    "companiesList": {"type":"object","additionalProperties":false,"required":["companies","registryVersion"],"properties":{"companies":{"type":"array","items":{"$ref":"#/$defs/companySummary"}},"registryVersion":{"const":1}}}
  }
}
