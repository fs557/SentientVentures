# Browser-safe setting. Do not place credentials in VITE_* variables.
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Local API configuration
SV_DATA_ROOT=./data/companies
SV_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8081
SV_MAX_FILE_BYTES=26214400
SV_MAX_AGGREGATE_FILE_BYTES=78643200
SV_OCR_ENABLED=false
SV_OCR_TEXT_THRESHOLD=100
SV_LLM_TIMEOUT_SECONDS=30
SV_LOG_LEVEL=INFO
SV_ENABLE_DEV_RESET=false

# Required only when live LLM processing is enabled.
SV_LLM_PROVIDER=
SV_LLM_MODEL=gpt-5.4-nano
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
SV_DEMO_RESET_TOKEN=
